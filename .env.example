# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=VisaFlow
APP_VERSION=1.0.0
DEBUG=false
SECRET_KEY=change-me-to-a-long-random-string

# ── Database ──────────────────────────────────────────────────────────────────
# DATABASE_ENV: "local" uses LOCAL_DATABASE_URL; "zoho" uses ZOHO_DATABASE_URL
DATABASE_ENV=local
LOCAL_DATABASE_URL=postgresql+asyncpg://user:password@host:5432/vyuflo
ZOHO_DATABASE_URL=postgresql+asyncpg://user:password@host:5432/zoho

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT ───────────────────────────────────────────────────────────────────────
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Storage (AWS S3) ──────────────────────────────────────────────────────────
STORAGE_BACKEND=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=vyuflo-env-name

# ── CORS / Cookies ────────────────────────────────────────────────────────────
# JSON array string
CORS_ORIGINS=["https://app.example.com"]
COOKIE_SECURE=true
FRONTEND_URL=https://app.example.com

# ── OAuth ─────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
APPLE_CLIENT_ID=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@visaflow.com
MAIL_STARTTLS=true
MAIL_SSL_TLS=false

# ── OCR / AI ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Zoho Analytics ────────────────────────────────────────────────────────────
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_ORG_ID=
ZOHO_WORKSPACE_ID=

# ── Rate limit / OTP ──────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
OTP_EXPIRE_MINUTES=10
OTP_MAX_ATTEMPTS=5
