# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=local
DEBUG=true
SECRET_KEY=change-me-to-a-long-random-string

# ── PostgreSQL (optional — used by Docker / local DB setup) ─────────────────────
POSTGRES_USER=your-postgres-user
POSTGRES_PASSWORD=your-postgres-password
POSTGRES_DB=vyuflo

# ── Database ──────────────────────────────────────────────────────────────────
# DATABASE_ENV: "local" uses LOCAL_DATABASE_URL; "zoho" uses ZOHO_DATABASE_URL
DATABASE_ENV=local
LOCAL_DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/vyuflo
ZOHO_DATABASE_URL=

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── CORS / Cookies ────────────────────────────────────────────────────────────
# JSON array string
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
COOKIE_SECURE=false
FRONTEND_URL=http://localhost:3000

# ── Storage ───────────────────────────────────────────────────────────────────
# "local" saves files under ./uploads; "s3" uses AWS below
STORAGE_BACKEND=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
S3_BUCKET=

# ── OCR / AI ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@visaflow.com

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── OAuth ─────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=

# ── Rate limit ────────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60

# ── Zoho Analytics ────────────────────────────────────────────────────────────
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_ORG_ID=
ZOHO_WORKSPACE_ID=
